# Template for secrets.dat  (vcell-ai-local / minikube)
# Copy this file to secrets.dat and fill in your actual values.
# DO NOT commit secrets.dat to git — it holds plaintext secrets.
#   cp secrets.dat.template secrets.dat && $EDITOR secrets.dat

# --- Backend (backend-secrets) ---
AZURE_API_KEY=your_azure_openai_api_key
LANGFUSE_SECRET_KEY=sk-lf-your-langfuse-secret-key
LANGFUSE_PUBLIC_KEY=pk-lf-your-langfuse-public-key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# --- Frontend (frontend-secrets) ---
# AUTH0_SECRET: 32-byte random string, e.g. `openssl rand -hex 32`
AUTH0_SECRET=your_auth0_session_secret
AUTH0_CLIENT_SECRET=your_auth0_client_secret

# --- GitHub Container Registry (ghcr-secret, image pull) ---
GH_USER_NAME=your_github_username
GH_USER_EMAIL=your_email@example.com
GH_PAT=ghp_YOURPERSONALACCESSTOKEN
